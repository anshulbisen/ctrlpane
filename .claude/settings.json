{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/worktree-enter.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/worktree-exit.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
