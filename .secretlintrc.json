{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend",
      "options": {
        "allows": [
          "postgresql://ctrlpane_app:ctrlpane_dev@localhost",
          "postgresql://ctrlpane_app:test@localhost"
        ]
      }
    }
  ],
  "ignorePatterns": [
    "docs/superpowers/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/.env.example",
    "**/test-helpers/**"
  ]
}
